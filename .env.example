# robotframework-superset — example environment.
# Copy to .env and edit. .env is git-ignored; never commit real secrets.

# ── Sink: PostgreSQL (shared by the event sink and Superset metadata) ──
# Host access uses port 5433 by default; inside docker the internal port is 5432.
DATABASE_URL=postgresql://rfs:changeme@localhost:5433/rfs
POSTGRES_USER=rfs
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rfs
POSTGRES_PORT=5433
POSTGRES_INTERNAL_PORT=5432

# ── Superset ──────────────────────────────────────────────────────────
SUPERSET_PORT=8088
# Generate a random value: python -c "import secrets; print(secrets.token_hex(32))"
SUPERSET_SECRET_KEY=generate-a-random-secret-here
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=changeme
SUPERSET_ADMIN_EMAIL=admin@example.local

# ── OpenAI feed ───────────────────────────────────────────────────────
# Billable secret — leave blank to disable the feed (it skips-and-logs).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Ollama feed ───────────────────────────────────────────────────────
# An Ollama server is UNAUTHENTICATED — never bind it to a public interface.
OLLAMA_ENDPOINT=http://localhost:11434
DEFAULT_MODEL=llama3

# ── Console / telnet listener ─────────────────────────────────────────
# Mode is "client" (tap a remote telnet device) or "server" (accept sessions).
CONSOLE_MODE=client
CONSOLE_HOST=127.0.0.1
CONSOLE_PORT=2323
